DB_CLIENT=mysql

HOST=127.0.0.1
PORT=3000
PUBLIC_BASE_URL=http://127.0.0.1:3000

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ta_system
MYSQL_CONNECTION_LIMIT=10

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_account@example.com
SMTP_PASS=your_app_password
SMTP_FROM=your_account@example.com

# 如果你明确要走本机 sendmail，而不是 SMTP，可以改成 Y。
# 一般更推荐配置上面的 SMTP。
MAIL_USE_SENDMAIL=N

SSO_LOGIN_URL=
SSO_LOGIN_X_STARTED=N
SSO_AUTH_URL=
SSO_TOKEN_URL=
SSO_USERINFO_URL=
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=
SSO_REDIRECT_URI=
SSO_LOGIN_NAME_FIELD=account
SSO_SCOPE=openid profile
